bruk terminal

gjer rekke(grense) {
    viss (grense < 2) gjer {
        gjevTilbake grense
    }
    gjevTilbake rekke(grense - 1) + rekke(grense - 2)
}

open tellar er 0
medan (tellar erMindreEnn 15) gjer {
    låst kalkulasjon er rekke(tellar)
    terminal.skriv(kalkulasjon)
    tellar er tellar + 1
}
