bruk terminal

gjer rekke(grense) {
    viss (grense < 2) gjer {
        gjevTilbake grense
    }
    gjevTilbake rekke(grense - 1) + rekke(grense - 2)
}

open teljar er 0
medan (teljar erMindreEnn 15) gjer {
    låst kalkulasjon er rekke(teljar)
    terminal.skriv(kalkulasjon)
    teljar er teljar + 1
}
