bruk terminal
bruk matte

gjer sjekkPrimtal(tall) {
    viss (tall erSameSom 1) gjer {
        gjevTilbake usant
    }

    open teller er 2
    medan (teller erMindreEnn tall) gjer {
        låst mod er matte.modulus(tall, teller)
        viss (mod erSameSom 0) gjer {
            gjevTilbake usant
        }
        teller er teller + 1
    }

    gjevTilbake sant
}

open teller er 0
medan (teller erMindreEnn 50) gjer {
    låst erPrimtal er sjekkPrimtal(teller)
    terminal.skriv(teller + " er eit primtal: " + erPrimtal)
    teller er teller + 1
}
