bruk kart
bruk terminal

gjer gangMedTi(nøkkel, verdi) {
  gjevTilbake verdi * 10
}

gjer behaldBerre(nøkkel, verdi) {
  gjevTilbake nøkkel erSameSom "b"
}

// Basic creation and lookup
låst minKart er kart.sett(kart.sett({}, "a", 1), "b", 2)
terminal.skriv(kart.hent(minKart, "a"))
terminal.skriv(kart.hent(minKart, "b"))
terminal.skriv(kart.lengd(minKart))

// Membership check
terminal.skriv(kart.inneheld(minKart, "a"))
terminal.skriv(kart.inneheld(minKart, "c"))

// Remove a key
låst nyKart er kart.fjern(minKart, "a")
terminal.skriv(kart.lengd(nyKart))

// Overwrite an existing key
låst endraKart er kart.sett(minKart, "a", 99)
terminal.skriv(kart.hent(endraKart, "a"))

// Literal with initial entries
låst storKart er { "x": 10, "y": 20 }
terminal.skriv(kart.hent(storKart, "x"))
terminal.skriv(kart.hent(storKart, "y"))

låst gangMedTiKart er kart.gjerOm(minKart, gangMedTi)
terminal.skriv(kart.hent(gangMedTiKart, "a"))
terminal.skriv(kart.hent(gangMedTiKart, "b"))

låst berreAndre er kart.filtrer(gangMedTiKart, behaldBerre)
terminal.skriv(kart.lengd(berreAndre))
terminal.skriv(kart.hent(berreAndre, "b"))
