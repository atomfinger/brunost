bruk terminal
bruk matte

open teljar er 1

medan (teljar erSameEllerMindreEnn 15) gjer {
    viss (matte.modulus(teljar, 15) erSameSom 0) gjer {
        terminal.skriv("FizzBuzz")
    } elles viss (matte.modulus(teljar, 3) erSameSom 0) gjer {
        terminal.skriv("Fizz")
    } elles viss (matte.modulus(teljar, 5) erSameSom 0) gjer {
        terminal.skriv("Buzz")
    } elles {
        terminal.skriv(teljar)
    }
    teljar er teljar + 1
}
