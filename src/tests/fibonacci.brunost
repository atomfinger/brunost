bruk terminal

gjer rekke(grense) {
    viss (grense < 2) gjer {
        gjevTilbake grense
    }
    gjevTilbake rekke(grense - 1) + rekke(grense - 2)
}

terminal.skriv(rekke(0))
terminal.skriv(rekke(1))
terminal.skriv(rekke(2))
terminal.skriv(rekke(3))
terminal.skriv(rekke(4))
terminal.skriv(rekke(5))
terminal.skriv(rekke(6))
